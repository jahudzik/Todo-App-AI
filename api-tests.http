### Health Check - Verify backend is running
GET http://localhost:3001/ping

### Get All Todo Lists - Should return seeded data
GET http://localhost:3001/api/lists

### Get All Todo Lists with Accept Header
GET http://localhost:3001/api/lists
Accept: application/json

### Test 404 Route - Should return not found error
GET http://localhost:3001/api/nonexistent

### Health Check with verbose headers
GET http://localhost:3001/ping
User-Agent: VSCode REST Client
Accept: application/json

### Test CORS headers
GET http://localhost:3001/api/lists
Origin: http://localhost:3000

### Create a new todo list (default name "New List")
POST http://localhost:3001/api/lists
Content-Type: application/json

### Create another new todo list to test ordering
POST http://localhost:3001/api/lists
Content-Type: application/json

### Update a todo list name - REPLACE WITH ACTUAL LIST ID
PATCH http://localhost:3001/api/lists/REPLACE_WITH_LIST_ID
Content-Type: application/json

{
  "name": "Updated Shopping List"
}

### Update list with validation error - empty name
PATCH http://localhost:3001/api/lists/REPLACE_WITH_LIST_ID
Content-Type: application/json

{
  "name": ""
}

### Update list with validation error - name too long
PATCH http://localhost:3001/api/lists/REPLACE_WITH_LIST_ID
Content-Type: application/json

{
  "name": "This is a very long list name that exceeds the 100 character limit and should cause a validation error to be returned by the API endpoint"
}

### Update list with HTML sanitization test
PATCH http://localhost:3001/api/lists/REPLACE_WITH_LIST_ID
Content-Type: application/json

{
  "name": "<script>alert('test')</script>Safe List Name"
}

### Update non-existent list (404 error)
PATCH http://localhost:3001/api/lists/non-existent-id
Content-Type: application/json

{
  "name": "This should fail"
}

### Delete a todo list - REPLACE WITH ACTUAL LIST ID
DELETE http://localhost:3001/api/lists/REPLACE_WITH_LIST_ID

### Delete non-existent list (404 error)
DELETE http://localhost:3001/api/lists/non-existent-id

### Delete with invalid ID format (400 error)
DELETE http://localhost:3001/api/lists/invalid-id-format

###############################################################################
# TODO ITEMS ENDPOINTS
###############################################################################

### Get items for a specific list - REPLACE WITH ACTUAL LIST ID
GET http://localhost:3001/api/items?listId=REPLACE_WITH_LIST_ID
Accept: application/json

### Get items with invalid list ID (400 error)
GET http://localhost:3001/api/items?listId=invalid-id-format
Accept: application/json

### Get items for non-existent list (404 error)
GET http://localhost:3001/api/items?listId=clistnonexistent1234567890123
Accept: application/json

### Get items without list ID parameter (400 error)
GET http://localhost:3001/api/items
Accept: application/json

### Create a new todo item - REPLACE WITH ACTUAL LIST ID
POST http://localhost:3001/api/items
Content-Type: application/json

{
  "title": "Buy milk",
  "listId": "REPLACE_WITH_LIST_ID"
}

### Create another todo item for testing ordering
POST http://localhost:3001/api/items
Content-Type: application/json

{
  "title": "Buy bread",
  "listId": "REPLACE_WITH_LIST_ID"
}

### Create item with validation error - empty title
POST http://localhost:3001/api/items
Content-Type: application/json

{
  "title": "",
  "listId": "REPLACE_WITH_LIST_ID"
}

### Create item with validation error - title too long
POST http://localhost:3001/api/items
Content-Type: application/json

{
  "title": "This is an extremely long todo item title that exceeds the 500 character limit. Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum.",
  "listId": "REPLACE_WITH_LIST_ID"
}

### Create item with HTML sanitization test
POST http://localhost:3001/api/items
Content-Type: application/json

{
  "title": "<script>alert('xss')</script>Clean up desk",
  "listId": "REPLACE_WITH_LIST_ID"
}

### Create item with missing listId (400 error)
POST http://localhost:3001/api/items
Content-Type: application/json

{
  "title": "This should fail"
}

### Create item for non-existent list (404 error)
POST http://localhost:3001/api/items
Content-Type: application/json

{
  "title": "This should fail",
  "listId": "clistnonexistent1234567890123"
}

### Update todo item title - REPLACE WITH ACTUAL ITEM ID
PATCH http://localhost:3001/api/items/REPLACE_WITH_ITEM_ID
Content-Type: application/json

{
  "title": "Buy organic milk"
}

### Update todo item completion status - REPLACE WITH ACTUAL ITEM ID
PATCH http://localhost:3001/api/items/REPLACE_WITH_ITEM_ID
Content-Type: application/json

{
  "isCompleted": true
}

### Update todo item position - REPLACE WITH ACTUAL ITEM ID
PATCH http://localhost:3001/api/items/REPLACE_WITH_ITEM_ID
Content-Type: application/json

{
  "positionInList": 2000
}

### Update item with multiple fields - REPLACE WITH ACTUAL ITEM ID
PATCH http://localhost:3001/api/items/REPLACE_WITH_ITEM_ID
Content-Type: application/json

{
  "title": "Buy almond milk",
  "isCompleted": false,
  "positionInList": 1500
}

### Update item with validation error - empty title
PATCH http://localhost:3001/api/items/REPLACE_WITH_ITEM_ID
Content-Type: application/json

{
  "title": ""
}

### Update item with invalid completion status
PATCH http://localhost:3001/api/items/REPLACE_WITH_ITEM_ID
Content-Type: application/json

{
  "isCompleted": "invalid"
}

### Update item with invalid position
PATCH http://localhost:3001/api/items/REPLACE_WITH_ITEM_ID
Content-Type: application/json

{
  "positionInList": -1
}

### Update non-existent item (404 error)
PATCH http://localhost:3001/api/items/citemnonexistent1234567890123
Content-Type: application/json

{
  "title": "This should fail"
}

### Update item with invalid ID format (400 error)
PATCH http://localhost:3001/api/items/invalid-id-format
Content-Type: application/json

{
  "title": "This should fail"
}

### Toggle item completion status - REPLACE WITH ACTUAL ITEM ID
POST http://localhost:3001/api/items/REPLACE_WITH_ITEM_ID/toggle
Content-Type: application/json

### Toggle non-existent item (404 error)
POST http://localhost:3001/api/items/citemnonexistent1234567890123/toggle
Content-Type: application/json

### Toggle item with invalid ID format (400 error)
POST http://localhost:3001/api/items/invalid-id-format/toggle
Content-Type: application/json

### Move item to new position - REPLACE WITH ACTUAL ITEM ID
PATCH http://localhost:3001/api/items/REPLACE_WITH_ITEM_ID/move
Content-Type: application/json

{
  "newPosition": 3000
}

### Move item relative to another position - REPLACE WITH ACTUAL ITEM ID
PATCH http://localhost:3001/api/items/REPLACE_WITH_ITEM_ID/move
Content-Type: application/json

{
  "insertAfterPosition": 2500
}

### Move item to end of list - REPLACE WITH ACTUAL ITEM ID
PATCH http://localhost:3001/api/items/REPLACE_WITH_ITEM_ID/move
Content-Type: application/json

{}

### Move item with invalid position value
PATCH http://localhost:3001/api/items/REPLACE_WITH_ITEM_ID/move
Content-Type: application/json

{
  "newPosition": -500
}

### Move item between sections (todo to done) - REPLACE WITH ACTUAL ITEM ID
PATCH http://localhost:3001/api/items/REPLACE_WITH_ITEM_ID/move-section
Content-Type: application/json

{
  "targetSection": "done"
}

### Move item between sections (done to todo) - REPLACE WITH ACTUAL ITEM ID
PATCH http://localhost:3001/api/items/REPLACE_WITH_ITEM_ID/move-section
Content-Type: application/json

{
  "targetSection": "todo"
}

### Move item with relative positioning in target section - REPLACE WITH ACTUAL ITEM ID
PATCH http://localhost:3001/api/items/REPLACE_WITH_ITEM_ID/move-section
Content-Type: application/json

{
  "targetSection": "done",
  "insertAfterPosition": 2000
}

### Move item with invalid target section
PATCH http://localhost:3001/api/items/REPLACE_WITH_ITEM_ID/move-section
Content-Type: application/json

{
  "targetSection": "invalid"
}

### Batch update multiple items - REPLACE WITH ACTUAL ITEM IDs
PATCH http://localhost:3001/api/items/batch
Content-Type: application/json

{
  "updates": [
    {
      "id": "REPLACE_WITH_ITEM_ID_1",
      "title": "Updated Item 1",
      "isCompleted": true
    },
    {
      "id": "REPLACE_WITH_ITEM_ID_2",
      "positionInList": 4000
    },
    {
      "id": "REPLACE_WITH_ITEM_ID_3",
      "title": "Updated Item 3",
      "isCompleted": false,
      "positionInList": 5000
    }
  ]
}

### Batch update with empty array (400 error)
PATCH http://localhost:3001/api/items/batch
Content-Type: application/json

{
  "updates": []
}

### Batch update with invalid item ID (400 error)
PATCH http://localhost:3001/api/items/batch
Content-Type: application/json

{
  "updates": [
    {
      "id": "invalid-id-format",
      "title": "This should fail"
    }
  ]
}

### Batch update with non-existent item (404 error)
PATCH http://localhost:3001/api/items/batch
Content-Type: application/json

{
  "updates": [
    {
      "id": "citemnonexistent1234567890123",
      "title": "This should fail"
    }
  ]
}

