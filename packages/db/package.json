    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@prisma/client": "^5.7.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "prisma": "^5.7.1",
    "typescript": "^5.3.2",
    "tsx": "^4.6.2",
    "eslint": "^8.56.0",
    "@typescript-eslint/parser": "^6.16.0",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.1.0"
  }
}